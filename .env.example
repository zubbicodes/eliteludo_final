# Copy this file to .env.local and fill in your Supabase project values.
# Anything prefixed with EXPO_PUBLIC_ is bundled into the client app.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only (used by supabase CLI / edge functions, never exposed to client)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
