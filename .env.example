# Copy this file to .env.local and fill in your Supabase project values.
# Anything prefixed with EXPO_PUBLIC_ is bundled into the client app.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Publishable / anon key — safe to ship to clients (security comes from RLS).
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_YOUR-KEY

# Server-only (used by supabase CLI / edge functions, never exposed to client)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
